# -----------------------------------------------------------------------------
# Segredos e configuração local (NUNCA commitar credenciais)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example

# -----------------------------------------------------------------------------
# Dependências
# -----------------------------------------------------------------------------
node_modules/
backend/node_modules/
frontend/node_modules/

# -----------------------------------------------------------------------------
# Build e artefatos gerados
# -----------------------------------------------------------------------------
dist/
build/
backend/dist/
frontend/dist/

# Cliente Prisma gerado (recriado via `prisma generate`)
generated/
backend/generated/

*.tsbuildinfo

# -----------------------------------------------------------------------------
# Logs, cache e arquivos temporários
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
logs/
cache/
tmp/
temp/
*.cache
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Testes e cobertura
# -----------------------------------------------------------------------------
coverage/
.vitest-cache/

# -----------------------------------------------------------------------------
# Banco de dados — dumps e backups (nunca versionar dados reais)
# -----------------------------------------------------------------------------
sql/
*.sql.gz
*.dump
sql/dumps/
sql/backups/

# -----------------------------------------------------------------------------
# Uploads e dados gerados pelo usuário
# -----------------------------------------------------------------------------
uploads/*
!uploads/.gitkeep
storage/*
!storage/.gitkeep

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml
*.pid

# -----------------------------------------------------------------------------
# Sistema operacional — Windows
# -----------------------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# -----------------------------------------------------------------------------
# Sistema operacional — macOS / Linux
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
*~
.directory

# -----------------------------------------------------------------------------
# IDEs e editores
# -----------------------------------------------------------------------------
.idea/
*.iml
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
*.sublime-project
*.sublime-workspace
*.code-workspace
.cursor/
**/.claude
**/.claude/**
**/skills/
**/SKILL.md

