# ============================================================
# Bevilacqua Labs — variaveis de deploy (raiz do projeto)
# Copie para .env e preencha. O .env NUNCA vai para o Git.
# ============================================================

# --- Dominio publico (Traefik) ---
# SITE: https://bevilabs.com.br  |  API: https://api.bevilabs.com.br
DOMAIN=seu.dominio.com.br
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

# --- Runtime da API ---
NODE_ENV=production
PORT=3000
# Origem do frontend (sem barra no fim). Com subdominio api., o site continua em https://seusite.com.br
# Aceita multiplos valores separados por virgula (ex.: com e sem www).
CORS_ORIGIN=https://seusite.com.br

# --- MySQL compartilhado (nome do container na rede mysql_shared) ---
MYSQL_HOST=mysql_shared
MYSQL_PORT=3306
MYSQL_DATABASE=databse
MYSQL_USER=seu_user
MYSQL_PASSWORD=sua_senha

# --- JWT (minimo 32 caracteres cada, secrets DIFERENTES) ---
# Gerar: openssl rand -base64 48
JWT_ACCESS_SECRET=mude-aqui
JWT_REFRESH_SECRET=mude-aqui
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Admin (usado apenas pelo seed, na primeira vez) ---
ADMIN_USERNAME=seu_user
ADMIN_PASSWORD=sua_senha

# --- Rate limit ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=120
