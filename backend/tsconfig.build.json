{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // rootDir na raiz do backend: inclui src/ e generated/prisma/ no mesmo bundle.
    "rootDir": "."
  },
  "include": ["src/**/*", "generated/**/*", "prisma/seed.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "prisma/migrations",
    "prisma/schema.prisma",
    "prisma.config.ts",
    "**/*.spec.ts",
    "test/**/*"
  ]
}
