// Prisma 7 — datasource sem `url`: a URL vive em prisma.config.ts (regra da skill).
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

/// Usuario administrativo do painel (/admin).
model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique(map: "uq_admin_users_username") @db.VarChar(64)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)

  refreshTokens RefreshToken[]

  @@map("admin_users")
}

/// Projeto exibido na secao "Meus projetos".
model Project {
  id          String   @id @db.Char(36)
  title       String   @db.VarChar(255)
  icon        String   @default("folder") @db.VarChar(32)
  description String   @db.Text
  link        String   @db.VarChar(2048)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)

  @@index([createdAt], map: "idx_projects_created_at")
  @@map("projects")
}

/// Hash do refresh token, para permitir rotacao e revogacao.
model RefreshToken {
  id        String    @id @db.Char(36)
  userId    Int       @map("user_id")
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.DateTime(0)
  revokedAt DateTime? @map("revoked_at") @db.DateTime(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(0)

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@map("refresh_tokens")
}
